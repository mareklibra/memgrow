{
  "private": true,
  "scripts": {
    "build": "NEXT_PUBLIC_BUILD_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo 'unknown') NEXT_PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) next build",
    "dev": "NEXT_PUBLIC_BUILD_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo 'unknown') NEXT_PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) next dev",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:local": "./scripts/test-local.sh",
    "prettier": "prettier --check './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "prettier:fix": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "chores": "pnpm prettier:fix && pnpm eslint:fix && pnpm prettier:fix &&pnpm tsc && pnpm test"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "@heroicons/react": "^2.2.0",
